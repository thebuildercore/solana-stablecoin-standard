{
  "compilerOptions": {
    "target": "ES2022",                                  
    "module": "NodeNext",                                
    "moduleResolution": "NodeNext",                      
    
    /* Emit Configuration */
    "outDir": "./dist",                                  
    "declaration": true,                                 
    "declarationMap": true,                              
    "sourceMap": true,                                   

    /* Strict Type-Checking Options */
    "strict": true,                                      
    "exactOptionalPropertyTypes": true,
    
    /* Module Resolution Options */
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "skipLibCheck": true                                 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}